// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User ────────────────────────────────────────────────────
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  avatar    String?
  role      Role     @default(DEVELOPER)
  level     SkillLevel @default(BEGINNER)
  xp        Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  repositories Repository[]
  progress     Progress[]
  bobLogs      BobUsageLog[]

  @@map("users")
}

enum Role {
  DEVELOPER
  MENTOR
  ADMIN
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

// ─── Repository ──────────────────────────────────────────────
model Repository {
  id          String   @id @default(cuid())
  userId      String
  name        String
  url         String
  branch      String   @default("main")
  description String?
  language    String?
  framework   String?
  status      RepoStatus @default(PENDING)
  analyzedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  analysis      RepositoryAnalysis?
  learningPaths LearningPath[]
  progress      Progress[]
  knowledgeBase KnowledgeEntry[]

  @@map("repositories")
}

enum RepoStatus {
  PENDING
  ANALYZING
  READY
  ERROR
}

// ─── Repository Analysis ─────────────────────────────────────
model RepositoryAnalysis {
  id           String   @id @default(cuid())
  repositoryId String   @unique
  complexity   Complexity @default(MEDIUM)
  fileCount    Int      @default(0)
  lineCount    Int      @default(0)
  dependencies Json     @default("[]")
  architecture Json     @default("{}")
  components   Json     @default("[]")
  patterns     String[] @default([])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@map("repository_analyses")
}

enum Complexity {
  LOW
  MEDIUM
  HIGH
}

// ─── Learning Path ────────────────────────────────────────────
model LearningPath {
  id             String   @id @default(cuid())
  repositoryId   String
  title          String
  description    String
  difficulty     Difficulty @default(BEGINNER)
  estimatedHours Int      @default(10)
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  repository Repository      @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  modules    LearningModule[]
  progress   Progress[]

  @@map("learning_paths")
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

// ─── Learning Module ──────────────────────────────────────────
model LearningModule {
  id               String   @id @default(cuid())
  learningPathId   String
  title            String
  description      String
  type             ModuleType @default(TUTORIAL)
  content          String   @db.Text
  codeExamples     Json     @default("[]")
  quiz             Json?
  challenge        Json?
  estimatedMinutes Int      @default(30)
  order            Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  learningPath LearningPath @relation(fields: [learningPathId], references: [id], onDelete: Cascade)

  @@map("learning_modules")
}

enum ModuleType {
  TUTORIAL
  CHALLENGE
  QUIZ
  PROJECT
}

// ─── Progress ─────────────────────────────────────────────────
model Progress {
  id               String   @id @default(cuid())
  userId           String
  repositoryId     String
  learningPathId   String
  completedModules String[] @default([])
  currentModuleId  String?
  score            Int      @default(0)
  timeSpentMinutes Int      @default(0)
  completionPct    Float    @default(0)
  startedAt        DateTime @default(now())
  lastActivityAt   DateTime @default(now())
  completedAt      DateTime?
  updatedAt        DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  repository   Repository   @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  learningPath LearningPath @relation(fields: [learningPathId], references: [id], onDelete: Cascade)

  @@unique([userId, learningPathId])
  @@map("progress")
}

// ─── Knowledge Base ───────────────────────────────────────────
model KnowledgeEntry {
  id           String   @id @default(cuid())
  repositoryId String
  type         KnowledgeType @default(FAQ)
  title        String
  content      String   @db.Text
  tags         String[] @default([])
  relatedFiles String[] @default([])
  views        Int      @default(0)
  helpful      Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@map("knowledge_entries")
}

enum KnowledgeType {
  FAQ
  DOC
  EXAMPLE
  PATTERN
}

// ─── IBM Bob Usage Tracking ───────────────────────────────────
model BobUsageLog {
  id           String   @id @default(cuid())
  userId       String?
  capability   BobCapability
  prompt       String   @db.Text
  response     String   @db.Text
  latencyMs    Int
  success      Boolean  @default(true)
  errorMessage String?
  tokensUsed   Int?
  mode         String   @default("mock") // "mock" or "live"
  createdAt    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("bob_usage_logs")
}

enum BobCapability {
  REPOSITORY_ANALYSIS
  LEARNING_PATH_GENERATION
  CODE_EXPLANATION
  DOCUMENTATION_GENERATION
  CODE_REVIEW
}